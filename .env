# ============================================================================
# KOWA RIDE - SUPERADMIN DASHBOARD
# Environment Variables
# ============================================================================
#
# HOW TO GET THESE VALUES:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project (or create a new one)
# 3. Navigate to: Project Settings → Database
#
# ============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# 1. DATABASE_URL (Required - Pooled Connection via PgBouncer)
# ──────────────────────────────────────────────────────────────────────────────
# Used by: Prisma Client for runtime queries
# Port: 6543 (PgBouncer pooler - required for serverless/edge)
# How to find: Supabase Dashboard → Settings → Database → Connection string → URI tab
#               Select "Transaction" mode (pooler)
#
# Format: postgresql://postgres.[PROJECT_REF]:[YOUR_DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Example: postgresql://postgres.abcdef123456:MyP@ssw0rd!@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR_DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# ──────────────────────────────────────────────────────────────────────────────
# 2. DIRECT_URL (Required - Direct Connection)
# ──────────────────────────────────────────────────────────────────────────────
# Used by: Prisma Migrate (schema migrations), admin operations
# Port: 5432 (Direct connection - no pooling)
# How to find: Same page as above, but select "Session" mode or direct connection
#
# Format: postgresql://postgres.[PROJECT_REF]:[YOUR_DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# Example: postgresql://postgres.abcdef123456:MyP@ssw0rd!@aws-0-us-east-1.pooler.supabase.com:5432/postgres
#
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR_DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ──────────────────────────────────────────────────────────────────────────────
# 3. NEXT_PUBLIC_SUPABASE_URL (Required - Supabase API URL)
# ──────────────────────────────────────────────────────────────────────────────
# Used by: Supabase client-side auth & realtime features
# How to find: Supabase Dashboard → Settings → API → Project URL
#
# Format: https://[PROJECT_REF].supabase.co
# Example: https://abcdef123456.supabase.co
#
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"

# ──────────────────────────────────────────────────────────────────────────────
# 4. NEXT_PUBLIC_SUPABASE_ANON_KEY (Required - Public API Key)
# ──────────────────────────────────────────────────────────────────────────────
# Used by: Supabase client-side operations (safe to expose in browser)
# How to find: Supabase Dashboard → Settings → API → Project API keys → anon public
#
# Format: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# (Long JWT token, ~200 characters)
#
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR_ANON_KEY]"

# ──────────────────────────────────────────────────────────────────────────────
# 5. SUPABASE_SERVICE_ROLE_KEY (Required - Server-side Admin Key)
# ──────────────────────────────────────────────────────────────────────────────
# Used by: Server-side operations that bypass Row Level Security (RLS)
# How to find: Supabase Dashboard → Settings → API → Project API keys → service_role secret
# ⚠️ NEVER expose this key in client-side code!
#
# Format: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# (Long JWT token, ~200 characters)
#
SUPABASE_SERVICE_ROLE_KEY="[YOUR_SERVICE_ROLE_KEY]"
