# ============================================================================
# KOWA RIDE - SUPERADMIN DASHBOARD
# Environment Variables Template
# ============================================================================
#
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# HOW TO GET THESE VALUES:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project (or create a new one)
# 3. Navigate to: Project Settings → Database  (for DB creds)
# 4. Navigate to: Project Settings → API        (for Supabase API creds)
#
# ============================================================================

# 1. DATABASE_URL — Pooled Connection via PgBouncer (port 6543)
# Used by: Drizzle ORM runtime queries
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR_DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# 2. DIRECT_URL — Direct Connection for Migrations (port 5432)
# Used by: drizzle-kit push/generate/migrate
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR_DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# 3. NEXT_PUBLIC_SUPABASE_URL — Supabase API URL
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"

# 4. NEXT_PUBLIC_SUPABASE_ANON_KEY — Public API Key
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR_ANON_KEY]"

# 5. SUPABASE_SERVICE_ROLE_KEY — Server-side Admin Key (NEVER expose client-side!)
SUPABASE_SERVICE_ROLE_KEY="[YOUR_SERVICE_ROLE_KEY]"

# 6. NEXTAUTH_SECRET — NextAuth.js Encryption Key
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="[GENERATE_A_RANDOM_32_CHAR_STRING]"

# 7. NEXTAUTH_URL — Base URL of your app
NEXTAUTH_URL="http://localhost:3000"
